# CalDAV — %u is replaced with CALDAV_USERNAME at runtime (Radicale path convention)
CALDAV_BASEURL=http://host.docker.internal:5232/%u
CALDAV_USERNAME=youruser
CALDAV_PASSWORD=yourpassword

# App
SITE_TITLE=Nodecal
DEFAULT_VIEW=day
TIMEZONE=Europe/Oslo
TIME_FORMAT=24h
WEEK_START=monday

# Optional: set a password to protect the app. Leave unset for open access.
# APP_PASSWORD=changeme

# Optional: bypass Nodecal's own password login when an upstream SSO / reverse
# proxy already authenticates requests. The app never prompts and the logout
# button is hidden. APP_PASSWORD can stay set (e.g. for a non-SSO path).
# BYPASS_AUTH=true
